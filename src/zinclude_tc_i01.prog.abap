MODULE user_command_0100 INPUT.
CASE sy-ucomm.
    WHEN 'BACK' OR 'EXIT' OR 'CANC'.
      LEAVE PROGRAM.
    WHEN 'EXPORT'.
      PERFORM f_export_to_excel.
  ENDCASE.
ENDMODULE.
